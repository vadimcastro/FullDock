# docker/frontend/Dockerfile.dev
FROM node:22-alpine
WORKDIR /opt/deps

# Set environment variables
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV npm_config_fetch_retries=5
ENV npm_config_fetch_retry_factor=2
ENV npm_config_fetch_retry_mintimeout=20000
ENV npm_config_fetch_retry_maxtimeout=120000
ENV npm_config_maxsockets=1
ENV npm_config_loglevel=error

# Install dependencies at build time
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --no-audit --no-fund || npm ci --no-audit --no-fund
RUN cp -a node_modules /opt/node_modules

WORKDIR /app

# Start the development server
CMD ["sh", "-c", "if [ ! -x /app/node_modules/.bin/next ]; then mkdir -p /app/node_modules && cp -a /opt/node_modules/. /app/node_modules/; fi && npm run dev"]
