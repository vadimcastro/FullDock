# docker/frontend/Dockerfile.dev
# Deps layer: install once, cached by Docker layer caching
FROM node:22-alpine AS deps
WORKDIR /app
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

COPY frontend/package.json frontend/package-lock.json* ./
# Final hardening for unstable networks: 
# - maxsockets 1 prevents the connection from being reset by the registry
# - high retries and long timeouts for flaky connections
RUN npm config set fetch-retry-mintimeout 30000 && \
    npm config set fetch-retry-maxtimeout 120000 && \
    npm config set fetch-retries 20 && \
    npm config set maxsockets 1 && \
    npm install --no-audit --no-fund --legacy-peer-deps

# Dev layer: bring in the pre-installed node_modules
FROM node:22-alpine AS dev
WORKDIR /app
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Copy node_modules from deps stage (no volume needed)
COPY --from=deps /app/node_modules ./node_modules

CMD ["npm", "run", "dev"]
