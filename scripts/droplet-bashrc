# ~/.bashrc: {{PROJECT_NAME}} Droplet Configuration
# Optimized bash configuration for production environment

# If not running interactively, don't do anything
[ -z "$PS1" ] && return

# History configuration - Enhanced for development workflow
HISTCONTROL=ignoredups:ignorespace
HISTSIZE=5000
case $- in
    *i*) ;;
      *) return;;
esac

# Don't put duplicate lines or lines starting with space in the history.
HISTCONTROL=ignoreboth
shopt -s histappend
HISTSIZE=10000
HISTFILESIZE=20000
shopt -s checkwinsize

[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac

if [ -n "$force_color_prompt" ]; then
    if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
        color_prompt=yes
    else
        color_prompt=
    fi
fi

if [ "$color_prompt" = yes ]; then
    PS1='${debian_chroot:+($debian_chroot)}\[\033[01;32m\]root@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='${debian_chroot:+($debian_chroot)}root@\h:\w\$ '
fi
unset color_prompt force_color_prompt

case "$TERM" in
xterm*|rxvt*)
    PS1="\[\e]0;\u@\h: \w\a\]$PS1"
    ;;
esac

# Environment variables
export DEPLOY_BRANCH_ENV=main

# Project navigation shortcuts
function fulldock() {
    cd /root/FullDock
}

# Git shortcuts
alias gs='git status'
alias ga='git add .'
alias gc='git commit -m'
alias gp='git push'
alias gl='git pull'
alias gb='git branch'
alias gco='git checkout'
alias glog='git log --oneline -1'

# Docker Compose shortcuts
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'
alias dcb='docker compose build'
alias dcr='docker compose down && docker compose up -d'

# Container shell access
alias dsh='docker compose exec backend bash'
alias dshf='docker compose exec frontend sh'
alias dshdb='docker compose exec db psql -U postgres -d fulldock'
alias dshr='docker compose exec redis redis-cli'

# Monitoring shortcuts
alias dps='docker compose ps'
alias dtop='docker stats'

# Custom status command on login
echo ""
echo "=== FullDock Server Environment ==="
echo "Branch: $DEPLOY_BRANCH_ENV"
echo ""
echo "Quick Commands:"
echo "  fulldock → cd /root/FullDock"

# System shortcuts
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias ..='cd ..'
alias home='cd ~'
alias c='clear'

# Shell config shortcuts
alias sb='source ~/.bashrc'
alias vb='vim ~/.bashrc'

# Generate and source bashrc from template
gsb() {
    cp scripts/droplet-bashrc ~/.bashrc && sb
}

# Development shortcuts
alias dev='make dev'
alias prod='make prod'
alias deploy='make deploy'
alias status='make droplet-status'
alias logs='make droplet-logs'
alias quick-deploy='make droplet-quick-deploy'

# Quick commit and push
function gcp() {
    git add . && git commit -m "$1" && git push
}

# Show all available aliases and functions
function shortcuts() {
    echo "📋 Available Shortcuts & Aliases:"
    echo ""
    echo "🗂️  Project Navigation:"
    echo "  {{PROJECT_NAME_CLEAN}} → cd /root/{{PROJECT_NAME}}"
    echo ""
    echo "🔧 Git Shortcuts:"
    echo "  gs → git status"
    echo "  ga → git add ."
    echo "  gc → git commit -m"
    echo "  gp → git push"
    echo "  gl → git pull"
    echo "  gb → git branch"
    echo "  gco → git checkout"
    echo "  glog → git log --oneline -1"
    echo "  gcp \"msg\" → git add . && commit && push"
    echo ""
    echo "🐳 Docker Shortcuts:"
    echo "  dps → docker ps"
    echo "  dclean → docker system prune -f"
    echo "  dlog → docker logs -f"
    echo "  dex → docker exec -it"
    echo ""
    echo "[INFO] Development:"
    echo "  dev → make dev"
    echo "  prod → make prod"
    echo "  deploy → make deploy"
    echo "  quick-deploy → make droplet-quick-deploy"
    echo "  status → make droplet-status"
    echo "  logs → make droplet-logs"
    echo ""
    echo "💡 System:"
    echo "  ll → ls -alF"
    echo "  la → ls -A"
    echo "  l → ls -CF"
    echo "  .. → cd .."
    echo "  home → cd ~"
    echo "  c → clear"
    echo "  sb → source ~/.bashrc"
    echo "  vb → vim ~/.bashrc"
    echo "  gsb → generate and source bashrc from template"
}

# Load bash completion if available
if [ -f /etc/bash_completion ] && ! shopt -oq posix; then
    . /etc/bash_completion
fi

# Load additional aliases if file exists
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi