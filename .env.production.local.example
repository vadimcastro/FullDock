# Production Environment Configuration (example only)
# Copy to .env.production.local and replace every placeholder value.

# Database
POSTGRES_USER=ondeck_prod
POSTGRES_PASSWORD=replace-with-strong-random-password-min-12
POSTGRES_DB=ondeck_prod
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/1

# Security
SECRET_KEY=replace-with-strong-random-secret-min-32
JWT_SECRET_KEY=replace-with-strong-random-secret-min-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILED_WINDOW_SECONDS=300
AUTH_LOCKOUT_SECONDS=900

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password-min-12
ADMIN_USERNAME=admin
ADMIN_NAME=Admin User

# Runtime
ENVIRONMENT=production
DEBUG=false

# CORS (required in production; no localhost/wildcards)
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Public/App URLs
# Frontend URL users land on after OAuth success/reset flows
OAUTH_POST_LOGIN_URL=https://app.example.com
# Backend OAuth redirect base (must match provider callback configuration)
OAUTH_REDIRECT_BASE=https://api.example.com/api/v1/oauth

# OAuth Providers (required if using social login)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# Validation
# Run: scripts/check-oauth-env.sh .env.production.local
